        ''',
    )

    dockerignore = ROOT / ".dockerignore"
    marker = "# BEGIN TELECOM PLATFORM GENERATED"
    block = dedent(
        '''
        # BEGIN TELECOM PLATFORM GENERATED
        .git
        .platform-backups
        **/__pycache__
        **/*.py[cod]
        **/.pytest_cache
        **/.mypy_cache
        **/.venv
        .env
        .env.platform
        # END TELECOM PLATFORM GENERATED
        '''
    ).lstrip()
    if dockerignore.exists():
        current = dockerignore.read_text(encoding="utf-8")
        if marker not in current:
            dockerignore.write_text(current.rstrip() + "\n\n" + block, encoding="utf-8")
    else:
        dockerignore.write_text(block, encoding="utf-8")

    env_path = ROOT / ".env.platform"
    if not env_path.exists():
        shutil.copy2(ROOT / ".env.platform.example", env_path)
        print("created .env.platform")
    else:
        print("kept existing .env.platform unchanged")


def validate() -> None:
    py_files = list((ROOT / "services").glob("*/app/*.py")) + list(
        (ROOT / "libs" / "common" / "common").glob("*.py")
    )
    for path in py_files:
        compile(path.read_text(encoding="utf-8"), str(path), "exec")
    print(f"Python syntax valid for {len(py_files)} generated files.")

    if shutil.which("docker"):
        try:
            subprocess.run(
                [
                    "docker",
                    "compose",
                    "--env-file",
                    ".env.platform",
                    "-f",
                    "docker-compose.platform.yml",
                    "config",
                ],
                cwd=ROOT,
                check=True,
                stdout=subprocess.DEVNULL,
            )
            print("Docker Compose configuration is valid.")
        except (subprocess.CalledProcessError, FileNotFoundError):
            print("WARNING: Docker Compose validation failed. Review the output with:")
            print("docker compose --env-file .env.platform -f docker-compose.platform.yml config")


def main() -> None:
    os.chdir(ROOT)
    generate()
    validate()
    print(
        """
Phase 3 generated successfully.

1) Review secrets:
   nano .env.platform

2) Start the platform:
   docker compose --env-file .env.platform -f docker-compose.platform.yml up --build -d

3) Watch logs:
   docker compose --env-file .env.platform -f docker-compose.platform.yml logs -f --tail=200

4) Test readiness:
   curl http://localhost:8080/health/ready

5) Run the end-to-end test:
   set -a; source .env.platform; set +a
   ./scripts/platform-smoke-test.sh

Workflow execution is MOCK and will not touch real routers.
"""
    )


if __name__ == "__main__":
    main()
